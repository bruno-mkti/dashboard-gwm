<title>GWM Euroville · Leads Formulário Meta</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800&family=Barlow:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--red:#CC0000;--bg:#0d0d0d;--bg2:#141414;--bg3:#1a1a1a;--bg4:#222;--brd:#252525;--brd2:#333;--tx:#f0f0f0;--tx2:#c0c0c0;--tx3:#909090;--Q:#CC0000;--M:#d4850a;--F:#4b8ef0;--Qbg:rgba(204,0,0,.12);--Mbg:rgba(212,133,10,.12);--Fbg:rgba(75,142,240,.12)}
body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--tx);font-size:13px}
.bar{background:var(--bg2);border-bottom:1px solid var(--brd);padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:54px;position:sticky;top:0;z-index:99}
.badge{background:var(--red);color:#fff;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:16px;padding:4px 11px;clip-path:polygon(7px 0%,100% 0%,calc(100% - 7px) 100%,0% 100%)}
.logo-t{font-family:'Barlow Condensed',sans-serif;font-size:14px;letter-spacing:2px;text-transform:uppercase;color:var(--tx2)}
.live{display:flex;align-items:center;gap:6px;background:rgba(34,197,94,.07);border:1px solid rgba(34,197,94,.2);border-radius:20px;padding:4px 10px;font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#22c55e}
.dot{width:6px;height:6px;border-radius:50%;background:#22c55e;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.wrap{padding:18px 24px}

/* FILTERS */
.filters{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;align-items:center}
.fu{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--tx2)}
select,input[type=date]{background:var(--bg3);border:1px solid var(--brd2);color:var(--tx);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 10px;border-radius:4px;cursor:pointer}
select:focus,input:focus{outline:none;border-color:var(--red)}
.btn-c{background:transparent;border:1px solid var(--brd2);color:var(--tx2);font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;padding:6px 12px;border-radius:4px;cursor:pointer;margin-left:auto}
.btn-c:hover{border-color:var(--red);color:var(--red)}

/* TABS */
.tabs{display:flex;gap:3px;margin-bottom:16px;border-bottom:1px solid var(--brd)}
.tab{font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;padding:9px 18px;border:none;background:transparent;color:var(--tx2);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:color .2s}
.tab.a{color:var(--red);border-bottom-color:var(--red)}
.tab:hover:not(.a){color:var(--tx)}

/* KPI */
.kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:16px}
.kpi{background:var(--bg2);border:1px solid var(--brd);border-radius:5px;padding:14px 16px;position:relative;overflow:hidden}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--kc,var(--red))}
.kl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--tx2);margin-bottom:8px}
.kv{font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:800;line-height:1}
.ks{font-size:10px;color:var(--tx2);margin-top:4px}

/* GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:12px}
.panel{background:var(--bg2);border:1px solid var(--brd);border-radius:5px;padding:16px}
.ptit{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--tx2);margin-bottom:14px;display:flex;align-items:center;gap:6px}
.ptit::before{content:'';width:3px;height:12px;background:var(--red);border-radius:1px;flex-shrink:0}

/* QUALITY PILLS */
.pill{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:3px;font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:.3px;text-transform:uppercase}
.pQ{background:var(--Qbg);color:var(--Q)}
.pM{background:var(--Mbg);color:var(--M)}
.pF{background:var(--Fbg);color:var(--F)}

/* BAR */
.barchart{display:flex;align-items:flex-end;gap:6px}
.bc{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.bv{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;color:var(--tx)}
.bf{width:100%;border-radius:2px 2px 0 0;min-height:3px}
.bl{font-size:9px;color:var(--tx2);text-align:center;line-height:1.3;font-family:'Barlow Condensed',sans-serif;text-transform:uppercase;letter-spacing:.3px}

/* DONUT */
.dw{display:flex;align-items:center;gap:14px}
.dl{display:flex;flex-direction:column;gap:8px;flex:1}
.dr{display:flex;align-items:center;gap:7px}
.ds{width:7px;height:7px;border-radius:2px;flex-shrink:0}
.dn{font-size:12px;color:var(--tx2);flex:1}
.dv{font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700}
.dp{font-size:10px;color:var(--tx2);min-width:30px;text-align:right}

/* TIMELINE BAR */
.tb{display:flex;flex-direction:column;gap:7px}
.tbr{display:flex;align-items:center;gap:8px}
.tbl{font-size:11px;color:var(--tx);width:130px;flex-shrink:0;text-align:right}
.tbt{flex:1;height:5px;background:var(--bg4);border-radius:3px;overflow:hidden}
.tbf{height:100%;border-radius:3px}
.tbv{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700;min-width:28px;text-align:right;color:var(--tx)}

/* UNIT CARDS */
.ug{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.uc{background:var(--bg2);border:1px solid var(--brd);border-radius:5px;padding:16px;position:relative;overflow:hidden}
.uc::after{content:'';position:absolute;top:0;left:0;bottom:0;width:3px;background:var(--uc)}
.uh{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;padding-left:12px}
.un{font-family:'Barlow Condensed',sans-serif;font-size:17px;font-weight:700}
.ucount{font-family:'Barlow Condensed',sans-serif;font-size:30px;font-weight:800;line-height:1;color:var(--uc)}
.uq{display:flex;gap:6px;margin-bottom:12px;padding-left:12px}
.uqp{flex:1;border-radius:4px;padding:7px 8px;text-align:center}
.uqn{font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;display:block;line-height:1}
.uql{font-size:9px;letter-spacing:.8px;text-transform:uppercase;opacity:.7}
.uf{padding-left:12px;border-top:1px solid var(--brd);padding-top:9px;font-size:11px;color:var(--tx2)}
.ubr{margin-top:8px;height:4px;border-radius:2px;overflow:hidden;display:flex;gap:1px}

/* TABLE */
.tw{background:var(--bg2);border:1px solid var(--brd);border-radius:5px;overflow:hidden}
.tscroll{overflow-x:auto}
table.lt{width:100%;border-collapse:collapse;font-size:12px}
table.lt thead tr{background:var(--bg3);border-bottom:2px solid var(--brd)}
table.lt th{padding:9px 12px;text-align:left;font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--tx2);font-weight:500;white-space:nowrap}
table.lt td{padding:8px 12px;border-bottom:1px solid var(--brd);color:var(--tx2)}
table.lt tr:hover td{background:var(--bg3)}
table.lt tr:last-child td{border-bottom:none}
.tfooter{padding:8px 12px;border-top:1px solid var(--brd);display:flex;justify-content:space-between;font-size:11px;color:var(--tx2);font-family:'Barlow Condensed',sans-serif;letter-spacing:.3px}

/* VEHICLE TABLE */
.vt{width:100%;border-collapse:collapse}
.vt td{padding:8px 0;border-top:1px solid var(--brd);vertical-align:middle}
.vt td:not(:first-child){text-align:right;font-family:'Barlow Condensed',sans-serif}
.vt th{font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--tx2);padding:0 0 10px;text-align:left;font-weight:500}
.vt th:not(:first-child){text-align:right}
.vnm{font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:700;display:flex;align-items:center;gap:7px}
.vdot{width:7px;height:7px;border-radius:2px;flex-shrink:0}
.vtbar{width:80px;display:inline-block}
.vtbt{height:3px;background:var(--bg4);border-radius:2px;overflow:hidden;margin-top:3px}
.vtbf{height:100%;background:var(--red);border-radius:2px}

/* QUALITY LEGEND */
.qleg{display:flex;gap:14px;margin-top:10px;font-size:10px;color:var(--tx2)}
.qleg div{display:flex;align-items:center;gap:5px}
.qleg span{width:7px;height:7px;border-radius:1px;display:inline-block}

::-webkit-scrollbar{width:3px;height:3px}::-webkit-scrollbar-track{background:var(--bg2)}::-webkit-scrollbar-thumb{background:var(--brd2)}::-webkit-scrollbar-thumb:hover{background:var(--red)}
@media(max-width:800px){.kpis{grid-template-columns:repeat(3,1fr)}.g2{grid-template-columns:1fr}.ug{grid-template-columns:1fr}}
</style>
</head>
