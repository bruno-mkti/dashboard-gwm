function barChart(items,colors,h=130){
  const mx=Math.max(...items.map(i=>i.v),1);
  return `<div class="barchart" style="height:${h}px;align-items:flex-end">${items.map((it,i)=>{
    const bh=Math.max(Math.round(it.v/mx*(h-36)),it.v>0?3:0);
    const c=Array.isArray(colors)?colors[i%colors.length]:colors;
    return `<div class="bc"><div class="bv">${it.v}</div><div class="bf" style="height:${bh}px;background:${c}"></div><div class="bl">${it.l}</div></div>`;
  }).join('')}</div>`;
}

function donut(data,size=110){
  const tot=data.reduce((s,d)=>s+d.v,0)||1;
  let cum=0;const r=44,cx=55,cy=55;
  function pol(p){const a=p*2*Math.PI-Math.PI/2;return[cx+r*Math.cos(a),cy+r*Math.sin(a)];}
  const paths=data.map(d=>{
    if(!d.v)return'';
    const pct=d.v/tot;
    const [x1,y1]=pol(cum);cum+=pct;
    const [x2,y2]=pol(cum);
    return `<path d="M${cx} ${cy} L${x1.toFixed(1)} ${y1.toFixed(1)} A${r} ${r} 0 ${pct>.5?1:0} 1 ${x2.toFixed(1)} ${y2.toFixed(1)}Z" fill="${d.c}" stroke="#141414" stroke-width="1.5"/>`;
  }).join('');
  const legend=data.map(d=>`<div class="dr"><div class="ds" style="background:${d.c}"></div><span class="dn">${d.l}</span><span class="dv" style="color:${d.c}">${d.v}</span><span class="dp">${Math.round(d.v/tot*100)}%</span></div>`).join('');
  return `<div class="dw"><svg width="${size}" height="${size}" viewBox="0 0 110 110">${paths}<circle cx="${cx}" cy="${cy}" r="26" fill="#141414"/><text x="${cx}" y="${cy}" text-anchor="middle" dominant-baseline="middle" font-size="16" font-weight="700" fill="#f0f0f0" font-family="Barlow Condensed,sans-serif">${tot}</text></svg><div class="dl">${legend}</div></div>`;
}

